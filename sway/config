# ─────────────────────────────────────────────────────────────────────────────
# SWAY CONFIG — converted from hyprland.conf
# for use with swayfx + gzml-shell
# ─────────────────────────────────────────────────────────────────────────────


# ─────────────────────────────────────────────────────────────────────────────
# VARIABLES
# ─────────────────────────────────────────────────────────────────────────────

set $mod      Mod4
set $terminal kitty
set $files    nemo
set $ipc      noctalia msg 


# ─────────────────────────────────────────────────────────────────────────────
# OUTPUT (MONITOR)
# ─────────────────────────────────────────────────────────────────────────────

output * {
    # auto-detect resolution — matches hyprland "preferred,auto,auto"
}


# ─────────────────────────────────────────────────────────────────────────────
# AUTOSTART
# ─────────────────────────────────────────────────────────────────────────────

exec noctalia
exec pkill kded6
exec sleep 3 && trayscale --window-type=utility --hide-window
exec udiskie --no-tray
exec /run/current-system/sw/bin/kdeconnect-indicator
exec autotiling

# pass env vars to dbus/systemd session
exec dbus-update-activation-environment --systemd \
    XDG_CURRENT_DESKTOP=sway \
    QT_QPA_PLATFORM=wayland \
    XCURSOR_SIZE=24 \
    XCURSOR_THEME=capitaine-cursors \
    QT_QPA_PLATFORMTHEME=qt6ct \
    GTK_THEME=adw-gtk3-dark \
    GSETTINGS_SCHEMA_DIR=/run/current-system/sw/share/glib-2.0/schemas \
    GTK_APPLICATION_PREFER_DARK_THEME=1


# ─────────────────────────────────────────────────────────────────────────────
# LOOK AND FEEL
# ─────────────────────────────────────────────────────────────────────────────

# borders (2px, matching hyprland)
default_border          pixel 2
default_floating_border pixel 2


# colors — inlined from colors.conf
# active border uses first color of hyprland gradient (#33ccff)
# class                  border    bg        text      indicator child_border
# client.focused           #33ccff   #33ccff   #e2e2e2   #00ff99   #33ccff
# client.unfocused         #595959   #131313   #e2e2e2   #595959   #595959
# client.focused_inactive  #595959   #1f1f1f   #e2e2e2   #595959   #595959

include ~/.config/sway/noctalia

# gaps
gaps inner 4
gaps outer 2
smart_gaps off

# ── swayfx effects ────────────────────────────────────────────────────────────
corner_radius 5

blur enable
blur_passes  1
blur_radius  4
blur_xray    off

# opacity: active = 0.95, inactive dimmed to ~0.60 (matches hyprland values)
for_window [app_id=".*"] opacity 0.95
default_dim_inactive 0.37

# shadows off (matches hyprland config)
shadows disable


# ─────────────────────────────────────────────────────────────────────────────
# INPUT
# ─────────────────────────────────────────────────────────────────────────────

input type:keyboard {
    xkb_layout  ie
    repeat_delay 400
    repeat_rate  30
}

input type:touchpad {
    natural_scroll disabled
    pointer_accel  0
    tap            enabled
}

input "epic-mouse-v1" {
    pointer_accel -0.5
}

focus_follows_mouse yes

# mod + LMB = move, mod + RMB = resize (replaces hyprland bindm)
floating_modifier $mod normal


# ─────────────────────────────────────────────────────────────────────────────
# WINDOW RULES
# ─────────────────────────────────────────────────────────────────────────────

for_window [app_id="scrcpy-wrapped"] {
    floating enable
    resize set 313 675
}

# for_window [app_id="kitty-microfetch"] {
    # floating enable
    # resize set 900 275
# }


# ─────────────────────────────────────────────────────────────────────────────
# KEYBINDINGS — APPS
# ─────────────────────────────────────────────────────────────────────────────

bindsym $mod+Return  exec $terminal
bindsym $mod+e       exec $files
bindsym $mod+b       exec helium
bindsym $mod+k       exec kdeconnect
bindsym $mod+Shift+b exec flatpak run waterfox
bindsym $mod+F12     exec kitty --class kitty-microfetch -e sh -c "microfetch; read -r"
bindsym $mod+c       exec claude-desktop


# ─────────────────────────────────────────────────────────────────────────────
# KEYBINDINGS — NOCTALIA SHELL IPC
# ─────────────────────────────────────────────────────────────────────────────

bindsym $mod+space           exec $ipc panel-toggle launcher
bindsym $mod+slash           exec $ipc settings-toggle
bindsym $mod+Escape          exec $ipc panel-toggle session
bindsym $mod+Print           exec $ipc screenshot-region

# control center: fires on Super key release (matches hyprland bindr behavior)
#bindsym --release Super_L    exec $ipc panel-toggle control-center
bindsym $mod+z exec $ipc panel-toggle control-center

bindsym Control+Shift+Escape exec $ipc panel-toggle control-center system
bindsym $mod+n               exec $ipc panel-toggle control-center notifications
bindsym $mod+Shift+v         exec $ipc panel-toggle clipboard

# window switcher (alt+tab — new in v5)
bindsym Alt+Tab              exec $ipc window-switcher


# ─────────────────────────────────────────────────────────────────────────────
# KEYBINDINGS — WINDOW MANAGEMENT
# ─────────────────────────────────────────────────────────────────────────────

bindsym $mod+q       kill
bindsym $mod+t exec swaymsg 'floating toggle; resize set 700 450'
bindsym $mod+v       layout toggle split
bindsym $mod+f       fullscreen
# sway has no "maximize with gaps" mode — both binds just toggle fullscreen
bindsym $mod+Shift+f fullscreen


# ─────────────────────────────────────────────────────────────────────────────
# KEYBINDINGS — FOCUS
# ─────────────────────────────────────────────────────────────────────────────

bindsym $mod+Left  focus left
bindsym $mod+Right focus right
bindsym $mod+Up    focus up
bindsym $mod+Down  focus down


# ─────────────────────────────────────────────────────────────────────────────
# KEYBINDINGS — WORKSPACES
# ─────────────────────────────────────────────────────────────────────────────

bindsym $mod+1 workspace number 1
bindsym $mod+2 workspace number 2
bindsym $mod+3 workspace number 3
bindsym $mod+4 workspace number 4
bindsym $mod+5 workspace number 5
bindsym $mod+6 workspace number 6
bindsym $mod+7 workspace number 7
bindsym $mod+8 workspace number 8
bindsym $mod+9 workspace number 9
bindsym $mod+0 workspace number 10

bindsym $mod+Shift+1 move container to workspace number 1
bindsym $mod+Shift+2 move container to workspace number 2
bindsym $mod+Shift+3 move container to workspace number 3
bindsym $mod+Shift+4 move container to workspace number 4
bindsym $mod+Shift+5 move container to workspace number 5
bindsym $mod+Shift+6 move container to workspace number 6
bindsym $mod+Shift+7 move container to workspace number 7
bindsym $mod+Shift+8 move container to workspace number 8
bindsym $mod+Shift+9 move container to workspace number 9
bindsym $mod+Shift+0 move container to workspace number 10

# move silently — sway doesn't follow focus to other workspaces by default
bindsym $mod+Mod1+1 move container to workspace number 1
bindsym $mod+Mod1+2 move container to workspace number 2
bindsym $mod+Mod1+3 move container to workspace number 3
bindsym $mod+Mod1+4 move container to workspace number 4
bindsym $mod+Mod1+5 move container to workspace number 5
bindsym $mod+Mod1+6 move container to workspace number 6
bindsym $mod+Mod1+7 move container to workspace number 7
bindsym $mod+Mod1+8 move container to workspace number 8
bindsym $mod+Mod1+9 move container to workspace number 9
bindsym $mod+Mod1+0 move container to workspace number 10

# scratchpad (equivalent to hyprland special:magic workspace)
bindsym $mod+s       scratchpad show
bindsym $mod+Shift+s move scratchpad

# scroll through workspaces with mouse wheel
bindsym $mod+button5 workspace next_on_output
bindsym $mod+button4 workspace prev_on_output


# ─────────────────────────────────────────────────────────────────────────────
# KEYBINDINGS — MEDIA + BRIGHTNESS
# ─────────────────────────────────────────────────────────────────────────────

# --locked = works on lockscreen too
bindsym --locked XF86AudioRaiseVolume  exec wpctl set-volume -l 1 @DEFAULT_AUDIO_SINK@ 5%+
bindsym --locked XF86AudioLowerVolume  exec wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%-
bindsym --locked XF86AudioMute         exec wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle
bindsym --locked XF86AudioMicMute      exec wpctl set-mute @DEFAULT_AUDIO_SOURCE@ toggle
bindsym --locked XF86MonBrightnessUp   exec brightnessctl -e4 -n2 set 5%+
bindsym --locked XF86MonBrightnessDown exec brightnessctl -e4 -n2 set 5%-

bindsym --locked XF86AudioNext  exec playerctl next
bindsym --locked XF86AudioPause exec playerctl play-pause
bindsym --locked XF86AudioPlay  exec playerctl play-pause
bindsym --locked XF86AudioPrev  exec playerctl previous
